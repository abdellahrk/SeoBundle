{
    "name": "abdellahramadan/seo-bundle",
    "description": "All in one Symfony SEO bundle",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["seo", "symfony", "schema", "structured data"],
    "autoload": {
        "psr-4": {
            "Abdellahramadan\\SeoBundle\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Abdellah Ramadan",
            "email": "ramadanabdel24@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "symfony/http-kernel": "^6.0 || ^7.0",
        "symfony/config": "^6.0 || ^7.0",
        "symfony/dependency-injection": "^6.0 || ^7.0",
        "twig/twig": "^3.20",
        "symfony/cache": "^6.0 || ^7.2",
        "abdellahramadan/open-graph-bundle": "^1.1"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "symfony/phpunit-bridge": "^7.2",
        "symfony/test-pack": "^1.0"
    }
}
